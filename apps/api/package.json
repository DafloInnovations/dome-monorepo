{
  "name": "@dome/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "prisma migrate deploy && node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "smoke-test": "PRODUCTION_URL=https://dome-monorepo-production.up.railway.app/api/v1 ts-node --transpile-only scripts/smoke-test.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  },
  "dependencies": {
    "@dome/types": "workspace:*",
    "@dome/utils": "workspace:*",
    "@prisma/client": "^6.1.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/node-cron": "^3.0.11",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.0",
    "twilio": "^6.0.2",
    "zod": "^3.24.1",
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@dome/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
