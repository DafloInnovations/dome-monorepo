NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://dome:dome_secret@localhost:5432/dome_dev
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=5

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Email (e.g. Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@dome.ca

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Testing — set to "true" to bypass Twilio OTP; any phone accepts code 000000
# NEVER enable this in production
TEST_MODE=false

# Google Maps
GOOGLE_MAPS_API_KEY=

# Sentry
SENTRY_DSN=
