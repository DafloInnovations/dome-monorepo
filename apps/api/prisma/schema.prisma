generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  PLAYER
  VENDOR
  ADMIN
}

enum Province {
  AB
  BC
  MB
  NB
  NL
  NS
  NT
  NU
  ON
  PE
  QC
  SK
  YT
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum SportType {
  SOCCER
  BASKETBALL
  TENNIS
  BADMINTON
  VOLLEYBALL
  HOCKEY
  SQUASH
  PICKLEBALL
  BASEBALL
  CRICKET
}

enum SurfaceType {
  TURF
  HARDWOOD
  CONCRETE
  CLAY
  ICE
  GRASS
  RUBBERIZED
}

enum SlotStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
  OPEN_GAME
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum BookingPaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  INTERAC_ETRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum OpenGameStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  JOIN_REQUEST
  PLAYER_CONFIRMED
  PLAYER_DECLINED
  NEW_MESSAGE
  GAME_FULL
  GAME_CANCELLED
  AVAILABILITY_ALERT
}

enum AlertStatus {
  PENDING
  TRIGGERED
  EXPIRED
  CANCELLED
}

enum SkillLevel {
  BEGINNER
  ROOKIE
  INTERMEDIATE
  ADVANCED
  PRO
  ELITE
  ANY
}

enum PlayerStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum BookingUnitType {
  COURT       // Badminton, Tennis, Squash, Pickleball
  LANE        // Bowling, Swimming
  TEE_TIME    // Golf
  SESSION     // Rock climbing, fitness classes
  PASS        // Gym day pass, open swim
  TABLE       // Table tennis, Pool/Snooker
}

enum BookingModel {
  SLOT_BASED  // Fixed time slots (most sports)
  TEE_TIME    // Golf — specific tee times
  SESSION     // Classes, climbing — session-based
  OPEN_PLAY   // Drop-in, day passes
}

enum GroupBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  PARTIAL_CANCELLED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum ConversationContext {
  BOOKING
  OPEN_GAME
  SUPPORT
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  phone           String   @unique
  email           String?  @unique
  passwordHash    String?
  firstName       String   @default("")
  lastName        String   @default("")
  avatarUrl       String?
  role               UserRole @default(PLAYER)
  province           Province @default(ON)
  isPhoneVerified    Boolean  @default(false)
  isEmailVerified    Boolean  @default(false)
  creditBalanceCAD   Decimal  @default(0) @db.Decimal(10, 2)
  deviceToken        String?
  emailBookingConfirmation Boolean @default(true)
  emailReminders           Boolean @default(true)
  emailMarketing           Boolean @default(false)
  // Player profile setup
  dateOfBirth        DateTime?  @db.Date
  gender             String?
  city               String?
  preferredSports    String[]
  profileComplete    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vendor                 Vendor?
  bookings               Booking[]
  bookingGroups          BookingGroup[]
  payments               Payment[]
  reviews                Review[]
  domeCredits            DomeCredit[]
  openGamesHosted        OpenGame[]                @relation("OpenGameHost")
  openGameParticipations OpenGameParticipant[]
  sentMessages           ChatMessage[]             @relation("MessageSender")
  conversations          ConversationParticipant[]
  refreshTokens          RefreshToken[]
  notifications          Notification[]
  recurringSeries        RecurringSeries[]
  availabilityAlerts     AvailabilityAlert[]
  couponUsages           CouponUsage[]

  @@index([phone])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Vendor ───────────────────────────────────────────────────────────────────

model Vendor {
  id                       String       @id @default(cuid())
  userId                   String       @unique
  businessName             String
  businessNumber           String?
  gstHstNumber             String?
  province                 Province     @default(ON)
  status                   VendorStatus @default(PENDING)
  stripeAccountId          String?      @unique
  stripeOnboardingComplete Boolean      @default(false)
  logoUrl                  String?
  website                  String?
  // Onboarding fields
  businessEmail            String?
  businessPhone            String?
  description              String?
  sports                   String[]
  streetAddress            String?
  city                     String?
  postalCode               String?
  rejectionReason          String?
  submittedAt              DateTime?
  approvedAt               DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilities Facility[]
  coupons    Coupon[]
}

// ─── Facility ─────────────────────────────────────────────────────────────────

model Facility {
  id          String      @id @default(cuid())
  vendorId    String
  name        String
  description String
  sport       SportType
  surface     SurfaceType
  capacity    Int
  images      String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookingModel              BookingModel @default(SLOT_BASED)
  cancellationWindowHours   Int          @default(24)

  vendor         Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  address        FacilityAddress?
  amenities      FacilityAmenityLink[]
  operatingHours OperatingHours[]
  courts         Court[]
  slots          Slot[]
  bookings       Booking[]
  bookingGroups  BookingGroup[]
  reviews        Review[]
  openGames      OpenGame[]
  recurringSeries RecurringSeries[]
  availabilityAlerts AvailabilityAlert[]
  equipment      Equipment[]
  coupons        Coupon[]

  @@index([vendorId])
  @@index([sport])
  @@index([isActive])
}

model FacilityAddress {
  id         String   @id @default(cuid())
  facilityId String   @unique
  street     String
  city       String
  province   Province
  postalCode String
  country    String   @default("CA")
  lat        Float?
  lng        Float?

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([province])
}

model Amenity {
  id       String  @id @default(cuid())
  name     String  @unique
  iconSlug String?

  facilities FacilityAmenityLink[]
}

model FacilityAmenityLink {
  facilityId String
  amenityId  String

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([facilityId, amenityId])
}

model OperatingHours {
  id         String  @id @default(cuid())
  facilityId String
  day        Int     // 0 = Sunday … 6 = Saturday
  openTime   String  // "HH:mm"
  closeTime  String  // "HH:mm"
  isClosed   Boolean @default(false)

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, day])
}

model Court {
  id           String          @id @default(cuid())
  facilityId   String
  name         String
  description  String?
  isActive     Boolean         @default(true)
  unitType     BookingUnitType @default(COURT)
  unitLabel    String          @default("Court")
  maxPlayers   Int?
  // Multi-sport shared court
  isShared     Boolean         @default(false)
  sports       String[]        // e.g. ["BADMINTON", "PICKLEBALL"]
  primarySport String?         // main sport shown in listings
  // Dynamic pricing
  dynamicPricingEnabled Boolean @default(false)
  // Booking duration rules
  minBookingMinutes   Int @default(60)
  durationStepMinutes Int @default(30)
  maxBookingMinutes   Int @default(180)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  facility           Facility             @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  slots              Slot[]
  pricingRules       PricingRule[]
  dateOverrides      DateOverride[]
  recurringSeries    RecurringSeries[]
  availabilityAlerts AvailabilityAlert[]
  sportPricing       CourtSportPricing[]

  @@index([facilityId])
}

model CourtSportPricing {
  id       String  @id @default(cuid())
  courtId  String
  sport    String
  priceCAD Decimal @db.Decimal(10, 2)

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, sport])
  @@index([courtId])
}

// ─── Dynamic Pricing ──────────────────────────────────────────────────────────

enum PricingRuleType {
  TIME_OF_DAY
  DAY_OF_WEEK
  PEAK_HOURS
  SEASONAL
  EARLY_BIRD
}

enum PriceAdjustmentType {
  PERCENTAGE_INCREASE
  PERCENTAGE_DECREASE
  FIXED_INCREASE
  FIXED_DECREASE
  FIXED_PRICE
}

enum DateOverrideType {
  CUSTOM_PRICE
  BLOCKED
  FREE
}

model PricingRule {
  id          String   @id @default(cuid())
  courtId     String
  name        String
  type        PricingRuleType

  daysOfWeek  Int[]
  startTime   String?
  endTime     String?
  startDate   DateTime?
  endDate     DateTime?

  adjustmentType  PriceAdjustmentType
  adjustmentValue Decimal @db.Decimal(10, 2)

  priority    Int     @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId, isActive])
}

model DateOverride {
  id             String          @id @default(cuid())
  courtId        String
  date           DateTime        @db.Date
  type           DateOverrideType
  customPriceCAD Decimal?        @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime        @default(now())

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, date])
  @@index([courtId])
}

// ─── Slots & Bookings ─────────────────────────────────────────────────────────

model Slot {
  id                String     @id @default(cuid())
  facilityId        String
  courtId           String?
  date              DateTime   @db.Date
  startTime         String     // "HH:mm"
  endTime           String     // "HH:mm"
  durationMinutes   Int
  priceCAD          Decimal    @db.Decimal(10, 2)
  status            SlotStatus @default(AVAILABLE)
  recurrenceGroupId String?
  // Multi-sport shared court fields
  sport             String?    // which sport this slot is for (null = court's facility sport)
  linkedSlotIds     String[]   // IDs of sibling slots on same court, same time, different sport
  blockReason       String?    // set when status=BLOCKED by a linked booking
  // Session / pass fields
  capacity          Int?       // non-null → SESSION slot; multiple bookings allowed up to this limit
  spotsBooked       Int        @default(0)
  isOpenPlay        Boolean    @default(false) // day-pass style, no specific time
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  facility Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  court    Court?    @relation(fields: [courtId], references: [id])
  bookings Booking[]
  openGame OpenGame?

  @@index([facilityId, date])
  @@index([courtId, date])
  @@index([status])
  @@index([recurrenceGroupId])
}

model Booking {
  id             String               @id @default(cuid())
  slotId         String?
  facilityId     String
  userId         String
  bookingGroupId String?
  status         BookingStatus        @default(PENDING)
  paymentStatus  BookingPaymentStatus @default(UNPAID)
  subtotalCAD    Decimal              @db.Decimal(10, 2)
  taxCAD         Decimal              @db.Decimal(10, 2)
  totalCAD       Decimal              @db.Decimal(10, 2)
  taxProvince    Province
  notes          String?
  cancelledAt      DateTime?
  cancelReason     String?
  creditsIssuedCAD     Decimal?             @db.Decimal(10, 2)
  shareCount           Int                  @default(0)
  equipmentTotalCAD    Decimal?             @db.Decimal(10, 2)
  paymentIntentId      String?
  recurringSeriesId    String?
  recurringSeriesIndex Int?
  couponId             String?
  couponCode           String?
  discountCAD          Decimal?             @db.Decimal(10, 2)
  creditsAppliedCAD    Decimal?             @db.Decimal(10, 2)
  cardChargeCAD        Decimal?             @db.Decimal(10, 2)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  slot             Slot?             @relation(fields: [slotId], references: [id])
  facility         Facility          @relation(fields: [facilityId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  bookingGroup     BookingGroup?     @relation(fields: [bookingGroupId], references: [id])
  recurringSeries  RecurringSeries?  @relation(fields: [recurringSeriesId], references: [id])
  payment          Payment?
  review           Review?
  domeCredits      DomeCredit[]
  conversations    Conversation[]
  equipmentRentals EquipmentRental[]
  couponUsage      CouponUsage?

  // One user can only hold one booking per slot (blocks double-booking for SESSION slots too)
  @@unique([slotId, userId])
  @@index([userId])
  @@index([facilityId])
  @@index([bookingGroupId])
  @@index([status])
  @@index([createdAt])
}

// ─── Group Booking ────────────────────────────────────────────────────────────

model BookingGroup {
  id              String             @id @default(cuid())
  userId          String
  facilityId      String
  totalCAD        Decimal            @db.Decimal(10, 2)
  subtotalCAD     Decimal            @db.Decimal(10, 2)
  taxCAD          Decimal            @db.Decimal(10, 2)
  status          GroupBookingStatus @default(PENDING)
  paymentStatus   PaymentStatus      @default(PENDING)
  paymentIntentId String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  facility Facility  @relation(fields: [facilityId], references: [id])
  bookings Booking[]
  payments Payment[]

  @@index([userId])
  @@index([facilityId])
  @@index([status])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  bookingId         String?       @unique  // null for group payments
  bookingGroupId    String?       @unique  // null for individual payments
  userId            String
  amountCAD         Decimal       @db.Decimal(10, 2)
  taxCAD            Decimal       @db.Decimal(10, 2)
  method            PaymentMethod
  gatewayPaymentId  String        @unique
  gatewayCustomerId String?
  status            PaymentStatus @default(PENDING)
  refundedAt        DateTime?
  refundAmountCAD   Decimal?      @db.Decimal(10, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  booking      Booking?      @relation(fields: [bookingId], references: [id])
  bookingGroup BookingGroup? @relation(fields: [bookingGroupId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model DomeCredit {
  id        String    @id @default(cuid())
  userId    String
  bookingId String?
  amountCAD Decimal   @db.Decimal(10, 2)
  reason    String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([bookingId])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  facilityId      String
  userId          String

  rating          Int       // 1–5
  title           String?
  body            String?

  courtQuality    Int?
  cleanliness     Int?
  valueForMoney   Int?
  staffFriendly   Int?

  sport           String    @default("")

  isVerified      Boolean   @default(true)
  isVisible       Boolean   @default(true)

  vendorReply     String?
  vendorRepliedAt DateTime?

  flaggedAt       DateTime?
  flagReason      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([facilityId, isVisible])
  @@index([userId])
  @@index([rating])
}

// ─── Open Games ───────────────────────────────────────────────────────────────

model OpenGame {
  id                String         @id @default(cuid())
  slotId            String?        @unique
  facilityId        String
  hostUserId        String
  sport             SportType
  title             String?
  description       String?
  status            OpenGameStatus @default(OPEN)
  skillLevel        SkillLevel     @default(ANY)
  maxPlayers        Int            @default(2)
  currentPlayers    Int            @default(1)
  // Connect feature fields (slotId-independent)
  gameDate          DateTime?      @db.Date
  startTime         String?
  endTime           String?
  playersNeeded     Int?
  playersConfirmed  Int            @default(0)
  pricePerPlayerCAD Decimal?       @db.Decimal(10, 2)
  isPublic          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  slot          Slot?                 @relation(fields: [slotId], references: [id])
  facility      Facility              @relation(fields: [facilityId], references: [id])
  host          User                  @relation("OpenGameHost", fields: [hostUserId], references: [id])
  participants  OpenGameParticipant[]
  conversations Conversation[]

  @@index([facilityId])
  @@index([hostUserId])
  @@index([status, sport])
  @@index([gameDate])
}

model OpenGameParticipant {
  id            String       @id @default(cuid())
  openGameId    String
  userId        String
  status        PlayerStatus @default(PENDING)
  joinedAt      DateTime     @default(now())
  confirmedAt   DateTime?
  paymentStatus String       @default("unpaid")

  openGame OpenGame @relation(fields: [openGameId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([openGameId, userId])
  @@index([userId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Conversation {
  id         String              @id @default(cuid())
  context    ConversationContext
  bookingId  String?
  openGameId String?
  title      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  booking      Booking?                  @relation(fields: [bookingId], references: [id])
  openGame     OpenGame?                 @relation(fields: [openGameId], references: [id])
  participants ConversationParticipant[]
  messages     ChatMessage[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
}

model ChatMessage {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(TEXT)
  isRead         Boolean     @default(false)
  readAt         DateTime?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

// ─── Recurring Bookings ───────────────────────────────────────────────────────

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum RecurringPaymentModel {
  PAY_PER_SESSION
  PAY_UPFRONT
}

enum RecurringSeriesStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

model RecurringSeries {
  id              String    @id @default(cuid())
  userId          String
  facilityId      String
  courtId         String

  startDate       DateTime  @db.Date
  endDate         DateTime  @db.Date
  startTime       String
  durationMinutes Int

  frequency    RecurringFrequency
  daysOfWeek   Int[]

  totalOccurrences      Int
  completedOccurrences  Int @default(0)
  cancelledOccurrences  Int @default(0)

  pricePerSessionCAD Decimal @db.Decimal(10, 2)
  discountPercent    Int     @default(0)

  paymentModel RecurringPaymentModel

  // Stripe — PAY_UPFRONT stores the group payment intent
  paymentIntentId       String?
  // PAY_PER_SESSION stores saved card details for future charges
  stripeCustomerId      String?
  stripePaymentMethodId String?

  status    RecurringSeriesStatus @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  facility Facility @relation(fields: [facilityId], references: [id])
  court    Court    @relation(fields: [courtId], references: [id])
  bookings Booking[]

  @@index([userId])
  @@index([facilityId])
  @@index([courtId])
  @@index([status])
}

// ─── Availability Alerts ──────────────────────────────────────────────────────

model AvailabilityAlert {
  id              String      @id @default(cuid())
  userId          String
  facilityId      String
  courtId         String?
  sport           String?

  date            DateTime    @db.Date
  startTime       String
  endTime         String
  durationMinutes Int

  status          AlertStatus @default(PENDING)
  triggeredAt     DateTime?
  expiresAt       DateTime

  createdAt       DateTime    @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  court    Court?   @relation(fields: [courtId], references: [id])

  @@unique([userId, facilityId, date, startTime, endTime])
  @@index([facilityId, date, status])
  @@index([userId, status])
  @@index([expiresAt, status])
}

// ─── Coupons ──────────────────────────────────────────────────────────────────

enum CouponType {
  PERCENTAGE
  FIXED
  FREE
}

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  description       String?

  type              CouponType
  value             Decimal    @db.Decimal(10, 2)

  vendorId          String?
  facilityId        String?
  sport             String?

  minBookingCAD     Decimal?   @db.Decimal(10, 2)
  maxDiscountCAD    Decimal?   @db.Decimal(10, 2)
  usageLimit        Int?
  usageLimitPerUser Int?       @default(1)
  usedCount         Int        @default(0)

  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean    @default(true)

  createdBy         String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  vendor   Vendor?       @relation(fields: [vendorId], references: [id])
  facility Facility?     @relation(fields: [facilityId], references: [id])
  usages   CouponUsage[]

  @@index([code])
  @@index([vendorId, isActive])
  @@index([isActive, validUntil])
}

model CouponUsage {
  id          String   @id @default(cuid())
  couponId    String
  userId      String
  bookingId   String   @unique
  discountCAD Decimal  @db.Decimal(10, 2)
  appliedAt   DateTime @default(now())

  coupon  Coupon  @relation(fields: [couponId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([couponId])
  @@index([userId])
}

// ─── Equipment ────────────────────────────────────────────────────────────────

model Equipment {
  id          String   @id @default(cuid())
  facilityId  String
  name        String
  description String?
  sport       String
  priceCAD    Decimal  @db.Decimal(10, 2)
  quantity    Int
  isActive    Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility    Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  rentals     EquipmentRental[]

  @@index([facilityId, isActive])
}

model EquipmentRental {
  id          String  @id @default(cuid())
  bookingId   String
  equipmentId String
  quantity    Int     @default(1)
  priceCAD    Decimal @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@index([bookingId])
  @@index([equipmentId])
}
